{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "promotix",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

# Promotix Agency - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Development: SQLite (file-based, no setup required)
# Production: PostgreSQL (recommended)
#   postgresql://user:password@host:5432/dbname
#   For Docker Compose with postgres service: postgresql://postgres:postgres@db:5432/promotix
DATABASE_URL=sqlite:///./promotix.db

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate a secure random secret: openssl rand -hex 32
# MUST be changed in production!
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins for the frontend
# Development: http://localhost:5173,http://localhost:3000
# Production:  https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# =============================================================================
# ADMIN CREDENTIALS (Development only - change in production!)
# =============================================================================
# Default admin user created on first startup if no admin exists
ADMIN_USERNAME=admin
ADMIN_PASSWORD=promotix123

# =============================================================================
# FRONTEND (Vite/React)
# =============================================================================
# API base URL used by frontend (Vite proxies /api in dev)
# In production with docker-compose, nginx proxies /api to backend
VITE_API_BASE_URL=/api

# =============================================================================
# OPTIONAL: PostgreSQL for Production (uncomment and configure)
# =============================================================================
# POSTGRES_USER=promotix
# POSTGRES_PASSWORD=secure_password_here
# POSTGRES_DB=promotix
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
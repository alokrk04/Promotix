{
  "name": "promotix-website",
  "version": "1.0.0",
  "private": true,
  "description": "Promotix website with admin content management",
  "main": "server.js",
  "scripts": {
    "start": "./backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --app-dir ./backend",
    "dev": "./backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --app-dir ./backend --reload --reload-exclude 'venv/**'",
    "start:express": "node server.js",
    "dev:express": "nodemon server.js",
    "setup:cert": "mkdir -p certs && openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout certs/localhost.key -out certs/localhost.crt -subj '/CN=localhost' -addext 'subjectAltName=DNS:localhost,IP:127.0.0.1' 2>/dev/null || true",
    "postinstall": "npm run setup:cert",
    "lint": "eslint . --ignore-pattern node_modules",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0",
    "vite": "^8.1.4"
  }
}

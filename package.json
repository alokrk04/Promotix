{
  "name": "promotix-website",
  "version": "1.0.0",
  "private": true,
  "description": "Promotix website with admin content management",
  "main": "server.js",
  "scripts": {
    "start": ".\\backend\\venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000 --app-dir .\\backend",
    "dev": ".\\backend\\venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000 --app-dir .\\backend --reload --reload-exclude venv/**",
    "start:express": "node server.js",
    "dev:express": "nodemon server.js",
    "setup:cert": "node -e \"const fs=require('fs'); const path=require('path'); fs.mkdirSync(path.join(process.cwd(),'certs'), { recursive: true });\"",
    "postinstall": "npm run setup:cert",
    "lint": "eslint . --ignore-pattern node_modules",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  }
}
